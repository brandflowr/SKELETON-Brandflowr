{
  "$schema": "https://raw.githubusercontent.com/brandflowr/SKELETON-Brandflowr/v2.9.0/spec/muscle.schema.json",
  "muscle_id": "note-stamper",
  "muscle_version": "1.0.0",
  "label": "Note Stamper",
  "description": "Demo transform MUSCLE: stamps an audit note into its own x-demo extension namespace on the first shot. Shows a capability-scoped patch being applied.",
  "hooks": [
    { "on": "entity.changed", "mode": "transform", "priority": 100, "timeout_ms": 10000 }
  ],
  "capabilities": ["read:document", "patch:extensions.x-demo"],
  "execution_routes": [
    { "type": "cli", "label": "Note Stamper (node)", "command": "node ../plugins/note-stamper.mjs" }
  ]
}
