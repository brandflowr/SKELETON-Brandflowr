{
  "$schema": "https://raw.githubusercontent.com/brandflowr/SKELETON-Brandflowr/v2.9.0/spec/bone.schema.json",
  "bone_id": "kling-v1",
  "bone_version": "1.0",
  "label": "Kling v1.6 (Video Generation)",
  "description": "Kuaishou Kling video generation. Text-to-video with mode, duration, and camera control.",
  "target": "video",
  "attaches_to": ["shot", "scene", "metadata"],
  "fields": {
    "text":            { "type": "string",  "required": true,  "ui": "textarea", "label": "Prompt" },
    "negative":        { "type": "string",  "required": false, "ui": "textarea", "label": "Negative Prompt" },
    "duration":        { "type": "number",  "required": false, "ui": "select",   "label": "Duration (seconds)", "options": [5, 10], "default": 5 },
    "mode":            { "type": "string",  "required": false, "ui": "select",   "label": "Mode", "options": ["standard", "pro"], "default": "standard" },
    "aspect":          { "type": "string",  "required": false, "ui": "select",   "label": "Aspect Ratio", "options": ["16:9", "9:16", "1:1"], "default": "16:9" },
    "reference_image": { "type": "string",  "required": false, "ui": "file",     "label": "Reference Image" },
    "camera_control":  { "type": "object",  "required": false, "ui": "text",     "label": "Camera Control", "description": "Camera movement parameters (pan, tilt, zoom, rotate)." }
  },
  "defaults": {
    "duration": 5,
    "mode": "standard",
    "aspect": "16:9"
  }
}
