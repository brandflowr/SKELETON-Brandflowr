{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/brandflowr/SKELETON-Brandflowr/main/spec/muscle.schema.json",
  "title": "MUSCLE Manifest",
  "description": "Validates .muscle.json behavior-plugin manifests. MUSCLE Spec v1.0.",
  "type": "object",
  "required": ["muscle_id", "muscle_version", "label", "hooks", "capabilities", "execution_routes"],
  "additionalProperties": false,
  "patternProperties": {
    "^x-": {}
  },
  "properties": {
    "$schema": { "type": "string" },
    "muscle_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Unique identifier. Lowercase alphanumerics and hyphens."
    },
    "muscle_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version of this manifest."
    },
    "label": { "type": "string" },
    "description": { "type": "string" },
    "hooks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/HookSubscription" }
    },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "#/definitions/Capability" },
      "description": "What this MUSCLE may read and patch. Hosts reject patches outside these."
    },
    "execution_routes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/ExecutionRoute" },
      "description": "How a host invokes this MUSCLE. Same shape as BONE Spec 2.7. First available, configured route wins."
    },
    "config_schema": {
      "type": "object",
      "description": "JSON Schema for per-project MUSCLE settings. Hosts may render a settings UI from it."
    },
    "extensions": {
      "type": "object",
      "description": "Vendor-specific extension data. Keys should be x- namespaced.",
      "additionalProperties": true
    }
  },
  "definitions": {
    "HookSubscription": {
      "type": "object",
      "required": ["on", "mode"],
      "additionalProperties": false,
      "properties": {
        "on": {
          "type": "string",
          "enum": [
            "import.before",
            "import.after",
            "document.validate",
            "prompt.assemble.before",
            "prompt.assemble.after",
            "generate.route",
            "render.complete",
            "entity.changed",
            "export.before",
            "export.after"
          ]
        },
        "mode": {
          "type": "string",
          "enum": ["observe", "transform", "veto"]
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "default": 100,
          "description": "Lower runs first. Ties break by registration order."
        },
        "timeout_ms": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "default": 30000
        },
        "filter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "formats": { "type": "array", "items": { "type": "string" } },
            "bone_ids": { "type": "array", "items": { "type": "string" } },
            "entities": {
              "type": "array",
              "items": { "type": "string", "enum": ["metadata", "act", "scene", "shot"] }
            }
          }
        }
      }
    },
    "Capability": {
      "type": "string",
      "oneOf": [
        {
          "enum": [
            "read:document",
            "read:sidecars",
            "patch:metadata",
            "patch:acts",
            "patch:scenes",
            "patch:shots",
            "patch:shot.bones",
            "patch:scene.bones",
            "patch:v_setup",
            "patch:sidecars",
            "write:renders"
          ]
        },
        {
          "pattern": "^patch:extensions\\.x-[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Patch only the named x- extension namespace on any entity."
        }
      ]
    },
    "ExecutionRoute": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "enum": ["mcp", "cli", "skill", "api", "manual"] },
        "label": { "type": "string" },
        "tool": { "type": "string" },
        "command": { "type": "string" },
        "endpoint": { "type": "string" },
        "requires": { "type": "array", "items": { "type": "string" } },
        "args": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
