{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/brandflowr/SKELETON-Brandflowr/main/spec/skel.schema.json",
  "title": "SKEL — Skeleton",
  "description": "A flat, relational SKEL data model for representing visual narratives. Native files are YAML; JSON is used for validation and export.",
  "type": "object",
  "required": ["skel_version", "metadata", "acts", "scenes", "shots"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "lifecycle": { "enum": ["production", "export"] }
            },
            "required": ["lifecycle"]
          }
        }
      },
      "then": {
        "properties": {
          "acts": {
            "minItems": 1,
            "items": {
              "properties": {
                "scene_refs": { "minItems": 1 }
              }
            }
          },
          "scenes": {
            "minItems": 1,
            "items": {
              "properties": {
                "shot_refs": { "minItems": 1 }
              }
            }
          },
          "shots": { "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "lifecycle": { "const": "export" }
            },
            "required": ["lifecycle"]
          }
        }
      },
      "then": {
        "required": ["bone_registry"]
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "required": ["bones"]
          }
        }
      },
      "then": {
        "required": ["bone_registry"]
      }
    },
    {
      "if": {
        "properties": {
          "acts": {
            "contains": {
              "required": ["bones"]
            }
          }
        }
      },
      "then": {
        "required": ["bone_registry"]
      }
    },
    {
      "if": {
        "properties": {
          "scenes": {
            "contains": {
              "required": ["bones"]
            }
          }
        }
      },
      "then": {
        "required": ["bone_registry"]
      }
    },
    {
      "if": {
        "properties": {
          "shots": {
            "contains": {
              "required": ["bones"]
            }
          }
        }
      },
      "then": {
        "required": ["bone_registry"]
      }
    }
  ],
  "properties": {
    "$schema": { "type": "string" },
    "skel_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Spec version (semver MAJOR.MINOR)."
    },
    "metadata": { "$ref": "#/definitions/Metadata" },
    "bone_registry": {
      "type": "object",
      "description": "Embedded BONE entries keyed by bone_id. May hold either the full canonical BONE definition (portable, self-contained) or a slim subset that resolves the rest from templates/bones or spec/bones at runtime.",
      "additionalProperties": { "$ref": "#/definitions/BoneRegistryEntry" }
    },
    "acts": {
      "type": "array",
      "items": { "$ref": "#/definitions/Act" }
    },
    "scenes": {
      "type": "array",
      "items": { "$ref": "#/definitions/Scene" }
    },
    "shots": {
      "type": "array",
      "items": { "$ref": "#/definitions/Shot" }
    },
    "characters": {
      "type": "array",
      "description": "Optional embedded character snapshots. Primary reference is by id (studio.json); embed on lifecycle: export for a portable, self-contained file.",
      "items": { "$ref": "#/definitions/Character" }
    },
    "environments": {
      "type": "array",
      "description": "Optional embedded environment snapshots. Primary reference is by id (studio.json); embed on export.",
      "items": { "$ref": "#/definitions/Environment" }
    },
    "audio_assets": {
      "type": "array",
      "description": "Optional embedded audio asset snapshots. Primary reference is via shots' sound_effects / audio-map.json; embed on export.",
      "items": { "$ref": "#/definitions/AudioAsset" }
    },
    "story_analysis": { "$ref": "#/definitions/StoryAnalysis" },
    "production": { "$ref": "#/definitions/Production" },
    "key_file": {
      "oneOf": [
        { "type": "string", "format": "uri" },
        { "$ref": "#/definitions/KeyFile" }
      ],
      "description": "Inline key file object or URI to external key file."
    }
  },
  "definitions": {
    "Extensions": {
      "type": "object",
      "description": "Vendor-namespaced extension data (keys must start with 'x-')."
    },
    "Bones": {
      "type": "object",
      "description": "BONE data keyed by bone_id. Values are open objects defined by the BONE definition.",
      "additionalProperties": { "type": "object" }
    },
    "BoneFieldDef": {
      "type": "object",
      "required": ["type", "required"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "enum": ["string", "number", "boolean", "array", "object"] },
        "required": { "type": "boolean" },
        "ui": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "default": {},
        "min": { "type": "number" },
        "max": { "type": "number" },
        "options": { "type": "array" }
      }
    },
    "BoneRegistryEntry": {
      "type": "object",
      "description": "Embedded form of a BONE in story.skel's bone_registry. Only the minimum needed for runtime resolution is required; full canonical fields (bone_version, attaches_to, per-field 'required') are accepted but not mandatory.",
      "required": ["label", "target", "fields"],
      "additionalProperties": true,
      "properties": {
        "bone_version": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "target": { "type": "string", "enum": ["image", "video", "audio", "style", "custom"] },
        "provider": { "type": "string" },
        "attaches_to": {
          "type": "array",
          "items": { "type": "string", "enum": ["metadata", "act", "scene", "shot"] }
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string" },
              "required": { "type": "boolean" },
              "ui": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" },
              "default": {},
              "min": { "type": "number" },
              "max": { "type": "number" },
              "options": { "type": "array" }
            }
          }
        },
        "defaults": { "type": "object" },
        "output": { "type": "object" }
      }
    },
    "BoneDefinition": {
      "type": "object",
      "required": ["bone_version", "label", "target", "attaches_to", "fields"],
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {
          "description": "Vendor-specific namespaced extension data.",
          "type": "object"
        }
      },
      "properties": {
        "bone_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "target": { "type": "string", "enum": ["image", "video", "audio", "style", "custom"] },
        "provider": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9\\-]*$",
          "description": "Optional provider namespace, such as higgsfield, runway, kling, or flux."
        },
        "attaches_to": {
          "type": "array",
          "items": { "type": "string", "enum": ["metadata", "act", "scene", "shot"] },
          "minItems": 1
        },
        "fields": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/BoneFieldDef" }
        },
        "defaults": { "type": "object" },
        "prompt_assembly": { "$ref": "#/definitions/PromptAssembly" },
        "llm_instructions": {
          "type": "object",
          "description": "Generator-specific writing guidance for LLM prompt authors.",
          "additionalProperties": true
        },
        "output": {
          "type": "object",
          "description": "Render output format, target, storage template, and write-back behavior.",
          "additionalProperties": true
        },
        "routing": {
          "type": "object",
          "description": "Optional provider routing metadata or lookup hints. Projects may also keep routing in external config.",
          "additionalProperties": true
        },
        "execution_routes": {
          "type": "array",
          "description": "Optional executable routes the agent can choose from, such as MCP, CLI, or skill package routes.",
          "items": { "$ref": "#/definitions/ExecutionRoute" }
        },
        "extensions": {
          "type": "object",
          "description": "Vendor-specific extension data. Keys should be x- namespaced.",
          "additionalProperties": true
        }
      }
    },
    "PromptAssembly": {
      "type": "object",
      "required": ["strategy"],
      "additionalProperties": false,
      "description": "Prompt assembly strategy and context injection rules.",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["template", "sequential", "raw"]
        },
        "template": {
          "type": "string",
          "description": "Template string using {{field_name}} and supported system tokens."
        },
        "v_setup_injection": { "$ref": "#/definitions/VSetupInjection" },
        "character_injection": { "$ref": "#/definitions/CharacterInjection" },
        "max_length": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum assembled prompt length in characters."
        },
        "separator": {
          "type": "string",
          "description": "Separator used by sequential assembly. Defaults to a single space."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "strategy": { "const": "template" } },
            "required": ["strategy"]
          },
          "then": { "required": ["template"] }
        }
      ]
    },
    "VSetupInjection": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "position": { "type": "string", "enum": ["append", "prepend", "inline"] },
        "token_format": { "type": "string", "enum": ["natural", "technical", "none"] },
        "tokens": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["size", "angle", "lens", "move", "light", "tod", "dof", "aspect", "color", "mood", "custom"]
          }
        }
      }
    },
    "CharacterInjection": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "position": { "type": "string", "enum": ["prepend", "append", "subject_prefix"] },
        "format": { "type": "string", "enum": ["name_only", "name_and_description", "consistency_modifier"] }
      }
    },
    "ExecutionRoute": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["mcp", "cli", "skill", "api", "manual"]
        },
        "label": { "type": "string" },
        "tool": { "type": "string" },
        "command": { "type": "string" },
        "endpoint": { "type": "string" },
        "requires": {
          "type": "array",
          "items": { "type": "string" }
        },
        "args": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "Constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "Metadata": {
      "type": "object",
      "required": ["story_id", "title"],
      "additionalProperties": false,
      "properties": {
        "story_id": { "type": "string" },
        "title": { "type": "string" },
        "lifecycle": {
          "type": "string",
          "enum": ["draft", "production", "export"],
          "default": "draft",
          "description": "Document lifecycle mode. Draft allows empty or partial structure; production/export apply stricter validation."
        },
        "logline": { "type": "string", "maxLength": 280 },
        "subtitle": { "type": "string" },
        "author": { "type": "string" },
        "director": { "type": "string" },
        "writer": { "type": "string" },
        "genre": { "type": "string" },
        "classification": { "type": "string" },
        "target_audience": { "type": "string" },
        "target_duration_seconds": { "type": "number", "minimum": 0 },
        "target_duration_minutes": { "type": "number", "minimum": 0 },
        "budget_range": { "type": "string" },
        "status": { "type": "string", "description": "Free-form production status label. Distinct from per-entity status.image/status.video." },
        "content_warnings": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "production_notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "modified_at": { "type": "string", "format": "date-time" },
        "skin_key": { "type": "string" },
        "source": { "$ref": "#/definitions/SourceProvenance" },
        "plugins": {
          "type": "array",
          "description": "Host-owned record of MUSCLE behavior plugins whose patches were applied to this document. Reproducibility metadata only — a document with unknown plugin records must still load everywhere.",
          "items": { "$ref": "#/definitions/PluginRecord" }
        },
        "constraints": { "$ref": "#/definitions/Constraints" },
        "bones": { "$ref": "#/definitions/Bones" },
        "extensions": { "$ref": "#/definitions/Extensions" }
      }
    },
    "SourceProvenance": {
      "type": "object",
      "description": "Where this document was imported from. Enables lossless round-trips: exporters back to the source format restore data parked under the matching x-<format> extension namespace.",
      "required": ["format"],
      "additionalProperties": false,
      "properties": {
        "format": { "type": "string", "description": "Source format id: fountain, fdx, otio, skel.json, csv, ..." },
        "file": { "type": "string", "description": "Original source file name or path." },
        "tool": { "type": "string", "description": "Tool that performed the import." },
        "imported_at": { "type": "string", "format": "date-time" }
      }
    },
    "PluginRecord": {
      "type": "object",
      "required": ["id", "version"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "muscle_id of the plugin." },
        "version": { "type": "string", "description": "muscle_version that ran." },
        "last_ran": { "type": "string", "format": "date-time" }
      }
    },
    "Act": {
      "type": "object",
      "required": ["id", "title", "scene_refs"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "order": { "type": "integer" },
        "title": { "type": "string" },
        "scene_refs": { "type": "array", "items": { "type": "string" } },
        "bones": { "$ref": "#/definitions/Bones" },
        "extensions": { "$ref": "#/definitions/Extensions" }
      }
    },
    "Loc": {
      "type": "object",
      "required": ["type", "name", "tod"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["INT", "EXT", "INT/EXT"] },
        "name": { "type": "string" },
        "tod": { "type": "string", "enum": ["DAY", "NIGHT", "DAWN", "DUSK", "CONT"], "default": "DAY" }
      }
    },
    "CreativeStatus": {
      "type": "string",
      "enum": ["idea", "drafted", "needs_review", "approved", "locked"],
      "description": "Story-development status for a scene or shot. Distinct from production status (status.image / status.video). 'locked' indicates creative content should not be modified by AI rewrites or automated edits."
    },
    "SceneIntent": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional creative purpose and structural function of the scene. Used by LLMs and directors to understand why a scene exists, not just what happens in it.",
      "properties": {
        "purpose": {
          "type": "string",
          "description": "What this scene reveals, establishes, or accomplishes for the story."
        },
        "conflict": {
          "type": "string",
          "description": "The dramatic tension or opposition driving this scene."
        },
        "emotional_turn": {
          "type": "string",
          "description": "How the emotional state or audience feeling changes from the scene's start to its end."
        },
        "story_function": {
          "type": "string",
          "enum": ["setup", "escalation", "reveal", "reaction", "decision", "transition", "payoff", "button"],
          "description": "The structural role this scene plays in the narrative arc."
        }
      }
    },
    "ShotIntent": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional creative purpose and emphasis for a single shot. LLMs MUST preserve intent when rewriting action or prompt text.",
      "properties": {
        "beat": {
          "type": "string",
          "description": "The specific story beat or moment this shot captures."
        },
        "function": {
          "type": "string",
          "enum": ["setup", "escalation", "reveal", "reaction", "decision", "transition", "payoff", "button"],
          "description": "The structural role this shot plays within its scene."
        },
        "emphasis": {
          "type": "string",
          "description": "What the shot should make the audience feel or notice. Used by LLMs when rewriting action or prompt text."
        }
      }
    },
    "Scene": {
      "type": "object",
      "required": ["id", "act_id", "header", "loc", "shot_refs"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "act_id": { "type": "string" },
        "order": { "type": "integer" },
        "header": { "type": "string" },
        "loc": { "$ref": "#/definitions/Loc" },
        "location_ref": { "type": "string" },
        "environment_ref": { "type": "string" },
        "shot_refs": { "type": "array", "items": { "type": "string" } },
        "narrative": { "type": "string" },
        "notes": { "type": "string" },
        "duration_seconds": { "type": "number", "minimum": 0 },
        "mood": { "type": "string" },
        "key_story_elements": { "type": "array", "items": { "type": "string" } },
        "intent": { "$ref": "#/definitions/SceneIntent" },
        "creative_status": { "$ref": "#/definitions/CreativeStatus" },
        "bones": { "$ref": "#/definitions/Bones" },
        "extensions": { "$ref": "#/definitions/Extensions" }
      }
    },
    "VSetup": {
      "type": "object",
      "required": ["size", "angle"],
      "additionalProperties": false,
      "properties": {
        "size":   { "type": "string", "enum": ["ws", "mws", "ms", "mcu", "cu", "ecu", "pov", "ots", "2s"] },
        "angle":  { "type": "string", "enum": ["eye", "low", "high", "dutch", "bird", "worm"] },
        "lens":   { "type": "string", "enum": ["wide", "std", "tele", "macro", "anamorphic"], "default": "std" },
        "move":   { "type": "string", "enum": ["static", "pan", "tilt", "dolly", "crane", "handheld", "steadicam", "drone"], "default": "static" },
        "light":  { "type": "string", "enum": ["natural", "noir", "high_key", "low_key", "golden", "blue", "practical", "neon"], "default": "natural" },
        "dof":    { "type": "string", "enum": ["deep", "shallow", "rack"], "default": "deep" },
        "aspect": { "type": "string", "enum": ["16:9", "9:16", "1:1", "4:3", "2.39:1", "21:9"] },
        "color":  { "type": "string" },
        "mood":   { "type": "string" }
      }
    },
    "Status": {
      "type": "object",
      "properties": {
        "image": { "type": "string", "enum": ["pending", "generating", "review", "approved", "rejected"] },
        "video": { "type": "string", "enum": ["not_started", "pending", "generating", "review", "approved", "rejected"] }
      },
      "additionalProperties": false
    },
    "Shot": {
      "type": "object",
      "required": ["id", "scene_id", "action", "v_setup"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "scene_id": { "type": "string" },
        "order": { "type": "integer" },
        "title": { "type": "string" },
        "action": { "type": "string", "maxLength": 200 },
        "visual_focus": { "type": "string" },
        "dialogue": {
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/definitions/Dialogue" }
          ],
          "description": "Either a plain spoken line (string) or a structured dialogue object with timing, emotion, and voice settings."
        },
        "character_refs": { "type": "array", "items": { "type": "string" } },
        "duration": { "type": "number", "minimum": 0 },
        "notes": { "type": "string" },
        "status": { "$ref": "#/definitions/Status" },
        "v_setup": { "$ref": "#/definitions/VSetup" },
        "cinematography": { "$ref": "#/definitions/Cinematography" },
        "sound_effects": { "type": "array", "items": { "$ref": "#/definitions/SoundCue" } },
        "intent": { "$ref": "#/definitions/ShotIntent" },
        "creative_status": { "$ref": "#/definitions/CreativeStatus" },
        "bones": { "$ref": "#/definitions/Bones" },
        "extensions": { "$ref": "#/definitions/Extensions" }
      }
    },
    "Dialogue": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": true,
      "description": "Structured dialogue: the spoken line plus timing, emotion, and voice direction.",
      "properties": {
        "text": { "type": "string" },
        "character_ref": { "type": "string" },
        "timing_start_seconds": { "type": "number", "minimum": 0 },
        "timing_end_seconds": { "type": "number", "minimum": 0 },
        "emotion": { "type": "string" },
        "delivery_notes": { "type": "string" },
        "voice_settings": { "type": "object", "additionalProperties": true }
      }
    },
    "SoundCue": {
      "type": "object",
      "required": ["audio_ref"],
      "additionalProperties": true,
      "description": "A per-shot reference to an audio asset with placement.",
      "properties": {
        "audio_ref": { "type": "string" },
        "timing_start_seconds": { "type": "number", "minimum": 0 },
        "timing_end_seconds": { "type": "number", "minimum": 0 },
        "volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "loop": { "type": "boolean" }
      }
    },
    "Cinematography": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional verbose camera + lighting detail for a shot. v_setup remains the canonical normalized (shorthand-token) form.",
      "properties": {
        "focal_length": { "type": "string" },
        "lens_type": { "type": "string" },
        "focus_subject": { "type": "string" },
        "framing_notes": { "type": "string" },
        "depth_of_field": { "type": "string" },
        "lighting": { "type": "object", "additionalProperties": true }
      }
    },
    "Character": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "description": "Embedded character snapshot (export/portable). Referenced by id from studio.json in working files.",
      "properties": { "id": { "type": "string" }, "name": { "type": "string" } }
    },
    "Environment": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "description": "Embedded environment snapshot (export/portable). Referenced by id from studio.json in working files.",
      "properties": { "id": { "type": "string" }, "name": { "type": "string" } }
    },
    "AudioAsset": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "description": "Embedded audio asset snapshot (dialogue/sfx/music).",
      "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "type": { "type": "string", "enum": ["dialogue", "sfx", "music"] } }
    },
    "StoryAnalysis": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional, informational story-development analysis. Does not affect validation strictness or generation."
    },
    "Production": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional, informational production planning + tracking. Tool-managed; not validated strictly."
    },
    "KeyFileToken": {
      "type": "object",
      "required": ["token", "label"],
      "additionalProperties": true,
      "properties": {
        "token": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" }
      }
